def render_pipeline(active: int):
    steps = [
        ("📂", "Upload"),
        ("🔍", "Detect"),
        ("🛠", "Fix"),
        ("✅", "Validate"),
    ]
    items_html = ""
    for i, (icon, label) in enumerate(steps):
        is_active = i < active or active == 4
        ring = "box-shadow:0 0 20px rgba(0,245,196,0.3);border-color:#00f5c4;background:rgba(0,245,196,0.1);" if is_active else ""
        lc   = "color:#00f5c4;" if is_active else "color:rgba(232,244,242,0.35);"
        items_html += f"""
        <div style="display:flex;flex-direction:column;align-items:center;gap:8px;">
          <div style="
            width:50px;height:50px;border-radius:50%;
            border:1.5px solid rgba(0,245,196,0.18);
            background:rgba(255,255,255,0.04);
            display:flex;align-items:center;justify-content:center;
            font-size:18px;transition:all .3s;{ring}
          ">{icon}</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;{lc}">{label}</div>
        </div>"""
        if i < len(steps) - 1:
            grad = "linear-gradient(90deg,rgba(0,245,196,0.3),transparent)" if is_active else "linear-gradient(90deg,rgba(0,245,196,0.1),transparent)"
            items_html += f"""
            <div style="height:1px;width:80px;background:{grad};margin-bottom:28px;flex-shrink:0;"></div>"""

    st.markdown(f"""
    <div style="display:flex;align-items:center;justify-content:center;gap:0;margin-bottom:40px;">
        {items_html}
    </div>""", unsafe_allow_html=True)

